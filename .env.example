# ── ЮKassa (оплата «Войти в бой») ─────────────────────────────────────────────
# Получить в https://yookassa.ru → Настройки → API-ключи
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Webhook в кабинете ЮKassa:
# https://warrior-point.vercel.app/api/payment/webhook

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — ТОЛЬКО сервер (API routes). Никогда не с префиксом NEXT_PUBLIC.
# Нужен для персистентности платежей (payment_intents) и серверных начислений.
# Supabase → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО задать в проде (подпись JWT-сессий). Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Токен бота из @BotFather — обязателен для входа через Telegram Mini App
# (HMAC-проверка initData). Без него telegram-логин отклоняется.
TELEGRAM_BOT_TOKEN=
