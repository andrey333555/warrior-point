# ── ЮKassa (оплата «Войти в бой») ─────────────────────────────────────────────
# Получить в https://yookassa.ru → Настройки → API-ключи
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Webhook в кабинете ЮKassa:
# https://warrior-point.vercel.app/api/payment/webhook

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Auth (опционально) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
